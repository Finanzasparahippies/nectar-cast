{
  "name": "nectar-cast-engine",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js",
    "package": "pkg dist/index.js --targets node18-linux-x64 --output dist/nectar-cast-engine"
  },
  "dependencies": {
    "node-media-server": "^2.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "esbuild": "^0.20.1",
    "pkg": "^5.8.1",
    "typescript": "^5.3.3"
  },
  "pkg": {
    "assets": [
      "node_modules/node-media-server/bin/**/*"
    ]
  }
}